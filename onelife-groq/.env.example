# Required for AI evolution (Groq)
REACT_APP_GROQ_KEY=gsk_your-groq-key-here

# Optional — live NAS100 data (Polygon.io free tier)
REACT_APP_POLYGON_KEY=your-polygon-key-here

# Optional — Telegram signal alerts
REACT_APP_TG_TOKEN=123456:ABC-DEF-YOUR-TOKEN
REACT_APP_TG_CHAT=-100234567890

# Optional — local MT5 bridge (dev only; production uses MT5_BRIDGE_URL on Vercel)
REACT_APP_MT5_BRIDGE_URL=http://127.0.0.1:5000

# ── Vercel server-side env vars (set in Vercel Dashboard → Settings → Environment Variables) ──
# GROQ_API_KEY=gsk_...
# POLYGON_API_KEY=your-polygon-key
# TG_TOKEN=your-telegram-bot-token
# TG_CHAT=your-chat-id
# MT5_BRIDGE_URL=https://your-ngrok-url.ngrok-free.app
